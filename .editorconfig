# EditorConfig — consistent coding styles across editors
# https://editorconfig.org

root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.lua]
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.toml]
indent_style = space
indent_size = 2

[*.sh]
indent_style = space
indent_size = 2

[*.conf]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
